# 后端镜像构建上下文：mining_risk_agent/
# 排除前端工程、缓存、IDE 等无关内容，加快镜像构建
__pycache__
*.pyc
*.pyo
*.pyd
.pytest_cache
.coverage
htmlcov
.mypy_cache

# 本地环境变量与密钥
.env
.env.*
!.env.example

# 前端 SPA 工程对后端镜像无意义
frontend/node_modules
frontend/dist
frontend/dist-tsbuild-node
frontend/.vite
frontend/*.tsbuildinfo

# Catboost 训练中间产物
catboost_info

# IDE / 系统
.vscode
.devcontainer
.git
.github
.DS_Store

# 模型与日志（容器内由 volume 提供）
logs/*.log

# 合并残留的重复文件
**/*_1.py
**/*_1.yml
**/*_1.yaml
**/*_1.json
**/*_1.txt
**/*_1.md
**/*_1.css
**/*_1.ts
**/*_1.tsx
**/*_1.svg
**/*_1.html
**/*_1.conf
**/*_1.pkl
**/*_1.example
**/*_1.xlsx
**/*_1.csv
**/*_1.gitkeep
